<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/FirstFragment">

    <fragment
        android:id="@+id/FirstFragment"
        android:name="com.rogger.xcast10.FirstFragment"
        android:label="@string/first_fragment_label"
        tools:layout="@layout/fragment_first">
        <argument
            android:name="deviceUrl"
            app:argType="string" />
        <argument
            android:name="videoTitle"
            app:argType="string" />
        <argument
            android:name="durationMs"
            app:argType="string" />

        <action
            android:id="@+id/action_FirstFragment_to_SecondFragment"
            app:destination="@id/SecondFragment" />
        <action
            android:id="@+id/action_firstFragment_to_galerryFragment"
            app:destination="@id/nav_gallery_fragment" />
    </fragment>
    <fragment
        android:id="@+id/nav_gallery_fragment"
        android:name="com.rogger.xcast10.gallery.GalleryFragment"
        android:label="@string/menu_gallery"
        tools:layout="@layout/fragment_gallery" >
        <action
            android:id="@+id/action_nav_gallery_fragment_to_SecondFragment"
            app:destination="@id/SecondFragment" />
    </fragment>
    <fragment
        android:id="@+id/SecondFragment"
        android:name="com.rogger.xcast10.ControloFragment"
        android:label="@string/second_fragment_label"
        tools:layout="@layout/fragment_controlo">

        <action
            android:id="@+id/action_SecondFragment_to_FirstFragment"
            app:destination="@id/FirstFragment" />
    </fragment>
</navigation>